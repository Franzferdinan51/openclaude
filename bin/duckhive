#!/usr/bin/env node

/**
 * DuckHive launcher - configures the terminal/provider environment and starts
 * the bundled CLI. Keep default startup aligned with OpenClaude's classic REPL;
 * optional daemons must not block stdin ownership before the UI is live.
 */

import { existsSync, readFileSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'
import { fork } from 'child_process'
import { applyLauncherProviderDefaults } from './duckhive-provider-bootstrap.js'

const __dirname = dirname(fileURLToPath(import.meta.url))

// Load .env file if present (node doesn't auto-load it like bun does)
const envPath = join(__dirname, '..', '.env')
if (existsSync(envPath)) {
  for (const line of readFileSync(envPath, 'utf-8').split('\n')) {
    const trimmed = line.trim()
    if (!trimmed || trimmed.startsWith('#')) continue
    const eqIdx = trimmed.indexOf('=')
    if (eqIdx === -1) continue
    const key = trimmed.slice(0, eqIdx).trim()
    const val = trimmed.slice(eqIdx + 1).trim()
    if (!(key in process.env)) process.env[key] = val
  }
}

const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

function isTruthy(value) {
  return ['1', 'true', 'yes', 'on'].includes(String(value || '').trim().toLowerCase())
}

function applyDefaultTerminalEnv(env = process.env) {
  if (process.platform !== 'win32') return

  if (!isTruthy(env.DUCKHIVE_ALLOW_FRAGILE_STDIN)) {
    delete env.DUCKHIVE_USE_DATA_STDIN
    delete env.OPENCLAUDE_USE_DATA_STDIN
    delete env.DUCKHIVE_USE_READABLE_STDIN
    delete env.OPENCLAUDE_USE_READABLE_STDIN
    delete env.DUCKHIVE_USE_CONIN_STDIN
  }

  if (process.platform === 'win32' && !isTruthy(env.DUCKHIVE_WINDOWS_EARLY_INPUT_EXPERIMENT)) {
    env.DUCKHIVE_DISABLE_EARLY_INPUT ??= '1'
  }
}

function shouldAutoStartCouncil(env = process.env) {
  return isTruthy(env.DUCKHIVE_AUTO_START_COUNCIL)
}

async function ensureCouncilDaemon() {
  const COUNCIL_PORT = process.env.COUNCIL_PORT || '3007'
  try {
    const controller = new AbortController()
    const id = setTimeout(() => controller.abort(), 1000)
    const res = await fetch(`http://localhost:${COUNCIL_PORT}/api/health`, { signal: controller.signal })
    clearTimeout(id)
    if (res.ok) return
  } catch {}

  const councilPath = join(__dirname, '..', 'src', 'services', 'council-server', 'council-api-server.cjs')
  if (!existsSync(councilPath)) return

  const child = fork(councilPath, [], {
    env: { ...process.env, PORT: COUNCIL_PORT, NODE_ENV: 'production' },
    detached: true,
    stdio: 'ignore',
  })
  child.unref()

  const deadline = Date.now() + 5000
  while (Date.now() < deadline) {
    await new Promise(r => setTimeout(r, 200))
    try {
      const res = await fetch(`http://localhost:${COUNCIL_PORT}/api/health`)
      if (res.ok) return
    } catch {}
  }
}

applyDefaultTerminalEnv()

let configApply = null
try {
  const loaderPath = join(__dirname, 'duckhive-config-loader.js')
  if (existsSync(loaderPath)) {
    const { loadDuckhiveConfig, applyConfigToEnv } = await import(pathToFileURL(loaderPath).href)
    const config = loadDuckhiveConfig()
    applyConfigToEnv(config)
    configApply = config
    applyLauncherProviderDefaults(process.env, config)
  }
} catch {}

if (!process.env.ANTHROPIC_SMALL_FAST_MODEL) {
  process.env.ANTHROPIC_SMALL_FAST_MODEL = 'gpt-4o-mini'
}

if (existsSync(distPath)) {
  if (shouldAutoStartCouncil()) {
    try {
      const timer = setTimeout(() => console.error('[duckhive] Council check timed out, continuing...'), 3000)
      await ensureCouncilDaemon()
      clearTimeout(timer)
    } catch (e) {
      console.error('[duckhive] Council error (non-fatal):', e.message)
    }
  }

  await import(pathToFileURL(distPath).href)
} else {
  console.error('duckhive: dist/cli.mjs not found. Run: bun run build')
  process.exit(1)
}
