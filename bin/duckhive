#!/usr/bin/env node

/**
 * DuckHive launcher — starts Council daemon, configures providers, launches REPL.
 */

import { existsSync } from 'fs'
import { join, dirname } from 'path'
import { fileURLToPath, pathToFileURL } from 'url'
import { fork } from 'child_process'

const __dirname = dirname(fileURLToPath(import.meta.url))
const distPath = join(__dirname, '..', 'dist', 'cli.mjs')

async function ensureCouncilDaemon() {
  const COUNCIL_PORT = process.env.COUNCIL_PORT || '3007'
  try {
    const controller = new AbortController()
    const id = setTimeout(() => controller.abort(), 1000)
    const res = await fetch(`http://localhost:${COUNCIL_PORT}/api/health`, { signal: controller.signal })
    clearTimeout(id)
    if (res.ok) return
  } catch {}
  const councilPath = join(__dirname, '..', 'src', 'services', 'council-server', 'council-api-server.cjs')
  if (!existsSync(councilPath)) return
  const child = fork(councilPath, [], {
    env: { ...process.env, PORT: COUNCIL_PORT, NODE_ENV: 'production' },
    detached: true,
    stdio: 'ignore',
  })
  child.unref()
  const deadline = Date.now() + 5000
  while (Date.now() < deadline) {
    await new Promise(r => setTimeout(r, 200))
    try {
      const res = await fetch(`http://localhost:${COUNCIL_PORT}/api/health`)
      if (res.ok) return
    } catch {}
  }
}

let configApply = null
try {
  const loaderPath = join(__dirname, 'duckhive-config-loader.js')
  if (existsSync(loaderPath)) {
    const { loadDuckhiveConfig, applyConfigToEnv } = await import(pathToFileURL(loaderPath).href)
    const config = loadDuckhiveConfig()
    applyConfigToEnv(config)
    configApply = config
    if (config?.providers?.default && !process.env.DUCKHIVE_PROVIDER) {
      process.env.DUCKHIVE_PROVIDER = config.providers.default
    }
  }
} catch {}

if ((configApply?.providers?.default === 'minimax' || process.env.MINIMAX_API_KEY) && process.env.MINIMAX_API_KEY && !process.env.CLAUDE_CODE_USE_OPENAI) {
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
  process.env.OPENAI_API_KEY = process.env.MINIMAX_API_KEY
  process.env.OPENAI_BASE_URL = 'https://api.minimax.io/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'MiniMax-M2.7'
}
if (!process.env.ANTHROPIC_SMALL_FAST_MODEL) {
  process.env.ANTHROPIC_SMALL_FAST_MODEL = 'gpt-4o-mini'
}
if (configApply?.providers?.default === 'kimi' && process.env.MINIMAX_API_KEY) {
  process.env.OPENAI_BASE_URL = 'https://api.moonshot.cn/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'moonshot-v1-128k'
} else if (configApply?.providers?.default === 'lmstudio') {
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
  process.env.OPENAI_API_KEY = process.env.OPENAI_API_KEY || 'lm-studio'
  process.env.OPENAI_BASE_URL = process.env.OPENAI_BASE_URL || 'http://localhost:1234/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'local-model'
} else if (configApply?.providers?.default === 'chatgpt' || configApply?.providers?.default === 'openai') {
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'gpt-5.4'
} else if (configApply?.providers?.default === 'openrouter') {
  process.env.OPENAI_BASE_URL = 'https://openrouter.ai/api/v1'
  process.env.OPENAI_MODEL = process.env.OPENAI_MODEL || 'minimax/minimax-m2.5:free'
}

if (existsSync(distPath)) {
  // Start Council daemon (3s timeout — non-blocking even if it fails)
  try {
    const timer = setTimeout(() => console.error('[duckhive] Council check timed out, continuing...'), 3000)
    await ensureCouncilDaemon()
    clearTimeout(timer)
  } catch (e) {
    console.error('[duckhive] Council error (non-fatal):', e.message)
  }

  await import(pathToFileURL(distPath).href)
} else {
  console.error(`duckhive: dist/cli.mjs not found. Run: bun run build`)
  process.exit(1)
}
