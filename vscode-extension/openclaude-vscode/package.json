{
  "name": "openclaude-vscode",
  "displayName": "DuckHive",
  "description": "Practical VS Code companion for DuckHive with project-aware launch behavior and a real Control Center.",
  "version": "0.2.0",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:openclaude.start",
    "onCommand:openclaude.startInWorkspaceRoot",
    "onCommand:openclaude.openDocs",
    "onCommand:openclaude.openSetupDocs",
    "onCommand:openclaude.openWorkspaceProfile",
    "onCommand:openclaude.openControlCenter",
    "onCommand:openclaude.newChat",
    "onCommand:openclaude.openChat",
    "onCommand:openclaude.resumeSession",
    "onCommand:openclaude.abortChat",
    "onView:openclaude.controlCenter",
    "onView:openclaude.chat"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "src/chat/**",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "openclaude.start",
        "title": "DuckHive: Launch in Terminal",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.startInWorkspaceRoot",
        "title": "DuckHive: Launch in Workspace Root",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.openDocs",
        "title": "DuckHive: Open Repository",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.openSetupDocs",
        "title": "DuckHive: Open Setup Guide",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.openWorkspaceProfile",
        "title": "DuckHive: Open Workspace Profile",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.openControlCenter",
        "title": "DuckHive: Open Control Center",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.newChat",
        "title": "DuckHive: New Chat",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.openChat",
        "title": "DuckHive: Open Chat Panel",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.resumeSession",
        "title": "DuckHive: Resume Session",
        "category": "DuckHive"
      },
      {
        "command": "openclaude.abortChat",
        "title": "DuckHive: Abort Generation",
        "category": "DuckHive"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openclaude",
          "title": "DuckHive",
          "icon": "media/openclaude.svg"
        }
      ]
    },
    "views": {
      "openclaude": [
        {
          "id": "openclaude.chat",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "openclaude.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openclaude.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      }
    ],
    "configuration": {
      "title": "DuckHive",
      "properties": {
        "openclaude.launchCommand": {
          "type": "string",
          "default": "duckhive",
          "description": "Command run in the integrated terminal when launching DuckHive."
        },
        "openclaude.terminalName": {
          "type": "string",
          "default": "DuckHive",
          "description": "Integrated terminal tab name for DuckHive sessions."
        },
        "openclaude.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched DuckHive terminals."
        },
        "openclaude.permissionMode": {
          "type": "string",
          "default": "acceptEdits",
          "enum": ["default", "acceptEdits", "bypassPermissions", "plan"],
          "enumDescriptions": [
            "Prompt for permission on each tool use (requires manual approval)",
            "Auto-approve file edits, prompt for other operations (recommended)",
            "Auto-approve all operations without prompting",
            "Read-only mode - no file modifications allowed"
          ],
          "description": "Permission mode for chat sessions. Controls which tool operations are auto-approved."
        }
      }
    },
    "themes": [
      {
        "label": "DuckHive Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/OpenClaude-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node scripts/lint.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "openclaude",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Franzferdinan51/DuckHive"
  },
  "license": "MIT"
}
