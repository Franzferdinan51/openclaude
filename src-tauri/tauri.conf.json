{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DuckHive",
  "version": "0.1.0",
  "identifier": "com.duckhive.app",
  "build": {
    "beforeBuildCommand": "cd ../webui && bun run build",
    "beforeDevCommand": "cd ../webui && bun run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../webui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DuckHive",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "windows": {
      "wix": null
    }
  }
}